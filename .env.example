# =====================================================
# ghost-delegate — EIP-7702 Nonce Domination Bot
# =====================================================
# Copy this file: cp .env.example .env
# Fill in your values below
# NEVER commit .env to GitHub!
# =====================================================

# =================== RPC ENDPOINTS ===================
# Get free endpoint at quicknode.com → Create Endpoint → Base → Mainnet
QUICKNODE_RPC=https://your-endpoint.quiknode.pro/your-key/
QUICKNODE_WS=wss://your-endpoint.quiknode.pro/your-key/

# Base sequencer — leave this as-is
SEQUENCER_RPC=https://mainnet-sequencer.base.org

# =================== WALLETS ===================
# Sponsor wallet — pays gas for all txs. Needs ETH on Base.
SPONSOR_PK=0x...

# Compromised wallet — the one under attack. You must still have the private key.
COMPROMISED_PK=0x...

# =================== CONTRACTS ===================
# Deploy contracts/Forwarder.sol on Remix (prague, Base mainnet) → paste address here
FORWARDER_ADDRESS=0x...

# Deploy contracts/AuthorizationExecutor.sol on Remix → paste address here
AUTH_EXECUTOR_ADDRESS=0x...

# Your safe wallet — ALL ETH will be auto-forwarded here
DESTINATION_ADDRESS=0x...

# =================== NONCE DOMINATION ===================
# Random jump size range — each tx fires this many EIP-7702 auths
NONCE_JUMP_MIN=30
NONCE_JUMP_MAX=80

# Gas settings — random between min and max (unpredictable to hackers)
GWEI_MIN=0.001
GWEI_MAX=0.004

# Gas limit per tx
GAS_LIMIT=1000000

# How often to fire (milliseconds)
FIRE_INTERVAL_MS=400

# =================== FEATURES ===================
# DRY_RUN=true  → test mode, no real txs sent
# DRY_RUN=false → LIVE MODE, real txs on Base mainnet
DRY_RUN=true

# ERC20 tokens to sweep (optional, comma-separated contract addresses)
TOKENS_TO_SWEEP=
